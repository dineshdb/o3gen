{
  "openapi": "3.0.0",
  "info": {
    "title": "Test API",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Status": {
        "type": "string",
        "enum": ["active", "inactive", "pending"]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": { "$ref": "#/components/schemas/Status" }
        },
        "required": ["id", "name"]
      },
      "Admin": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "permissions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Role": {
        "anyOf": [
          { "$ref": "#/components/schemas/User" },
          { "$ref": "#/components/schemas/Admin" },
          { "type": "string" }
        ]
      },
      "ComplexAnyOf": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["A"] },
              "value_a": { "type": "integer" }
            }
          },
          {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["B"] },
              "value_b": { "type": "string" }
            }
          }
        ]
      }
    }
  }
}
